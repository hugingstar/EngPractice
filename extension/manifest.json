{
  "manifest_version": 3,
  "name": "Learner Pro",
  "version": "1.0",
  "description": "유튜브 영상을 시청하다 클릭하면 즉시 Language Learner Pro 앱으로 텔레포트합니다.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_icon": "icon.png",
    "default_title": "Learner Pro로 열기"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
