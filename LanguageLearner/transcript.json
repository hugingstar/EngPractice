[[{"text": "\uc5ec\ub7ec\ubd84, \uc548\ub155\ud558\uc138\uc694.", "start": 5.19, "duration": 1.02}, {"text": "\uc800 \ub86d\uacfc \ud568\uaed8\ud558\ub294 \ud31f\uce90\uc2a4\ud2b8\n\uc774\ubc88 \uc5d0\ud53c\uc18c\ub4dc\uc5d0\ub3c4 \uc798 \uc624\uc168\uc5b4\uc694.", "start": 6.235, "duration": 5.44}, {"text": "\uc800 \ub2ec\ub9ac\uc544\ub3c4 \ud568\uaed8\ud569\ub2c8\ub2e4. \uc548\ub155\ud558\uc138\uc694.", "start": 11.7, "duration": 1.71}, {"text": "\uc548\ub155\ud558\uc138\uc694. \uc120\uc0dd\ub2d8, \uc798 \uc9c0\ub0c8\ub098\uc694?", "start": 13.435, "duration": 1.75}, {"text": "\uc544\uc8fc \uc798 \uc9c0\ub0c8\uc5b4\uc694. \ub298 \uadf8\ub807\ub4ef\uc774 \ud2b9\ubcc4\ud788\n\ud765\ubbf8\ub85c\uc6b4 \uac74 \ub5a0\uc624\ub974\uc9c0 \uc54a\uc9c0\ub9cc\uc694. \ud615\ud3b8\uc5c6\ub294 \ud638\uc2a4\ud2b8\ub124\uc694.", "start": 15.21, "duration": 5.61}, {"text": "\uc544, \uadf8\ub798\ub3c4 \uad1c\ucc2e\uc544\uc694.\n\uc800\ub3c4 \ud559\uc0dd\ub4e4\uacfc \uadf8\ub7f0 \uc77c\uc774 \ub9ce\uc740\ub370\uc694.", "start": 20.845, "duration": 4.98}, {"text": "\uc81c\uac00 \ud56d\uc0c1 \uc774\ub807\uac8c \ubb3c\uc5b4\ubcf4\uac70\ub4e0\uc694. \"\uc0c8\ub85c\uc6b4 \uc77c \uc788\ub098\uc694?\n\uc9c0\ub09c\uc8fc\uc5d0 \ud765\ubbf8\ub85c\uc6b4 \uc77c\uc740 \uc5c6\uc5c8\ub098\uc694?\"\ub77c\uace0\uc694.", "start": 25.85, "duration": 5.03}, {"text": "\uadf8\ub7fc \ub2e4\ub4e4 \"\uc5c6\uc5b4\uc694!\"\ub77c\uace0 \ud558\ub354\ub77c\uace0\uc694.", "start": 30.905, "duration": 0.871}, {"text": "\uadf8\ub7ec\ub2c8\uae4c\uc694.", "start": 31.8, "duration": 1.2}, {"text": "\uadf8\ub7fc \uc800\ub3c4 \uad1c\ucc2e\ub2e4\uace0 \uc598\uae30\ud574\uc694.", "start": 33.0, "duration": 2.631}, {"text": "\uc194\uc9c1\ud788 \ub9d0\ud558\uba74 \uc81c \uc778\uc0dd\ub3c4 \uc2e0\ub098\ub294 \ubaa8\ud5d8\uacfc\n\uc7a5\ub09c\uae30 \ub118\uce58\ub294 \uc77c\uc758 \uc5f0\uc18d\uc740 \uc544\ub2c8\uac70\ub4e0\uc694.", "start": 35.631, "duration": 6.899}, {"text": "\uadf8\ub807\uc8e0.", "start": 42.555, "duration": 0.78}, {"text": "\uadf8\ub798\ub3c4 \ud558\ub098 \uc788\uae34 \ud574\uc694.\n\ucd5c\uadfc\uc5d0 \uc0ac\uaca9\uc744 \ud558\ub7ec \uac14\uc5b4\uc694. \ucd1d \uc3d8\ub294 \uc0ac\uaca9\uc774\uc694.", "start": 43.36, "duration": 6.125}, {"text": "\uc815\ub9d0\uc694? \uc9c0\ub09c\uc8fc\uc5d4 \uc694\ud2b8\ub97c \ud0c0\uc2dc\ub354\ub2c8 \uc774\ubc88 \uc8fc\ub294\n\uc0ac\uaca9\uc774\ub124\uc694. \ub2e4\uc74c \uc8fc\ub294 \ubb54\uac00\uc694? \ub3c4\ub07c \ub358\uc9c0\uae30?", "start": 49.51, "duration": 5.885}, {"text": "\ub3c4\ub07c \ub358\uc9c0\uae30\ub3c4 \ud574\ubcf8 \uc801 \uc788\uae34 \ud574\uc694.\n\ud558\uc9c0\ub9cc \uc774\ubc88\uc5d4\u2026 \uadf8 \ub2e4\uc74c\uc5d4 \uc544\ub9c8 \uae00\ub7a8\ud551\uc744 \uac08 \uac83 \uac19\uc544\uc694.", "start": 55.395, "duration": 6.921}, {"text": "\uc544, \uba4b\uc9c0\ub124\uc694.", "start": 62.341, "duration": 1.834}, {"text": "\ub124. \uc81c\uac00 \uc0ac\ub294 \ub3c4\uc2dc\uc5d0 \uc0c8\ub85c\uc6b4 \uc0ac\uaca9\uc7a5\uc774 \uc5f4\uc5c8\uac70\ub4e0\uc694.\n\uc2e4\ub0b4 \uc0ac\uaca9\uc744 \ud560 \uc218 \uc788\ub294 \uacf3\uc774\uace0,", "start": 64.2, "duration": 10.421}, {"text": "BB\ud0c4\uc774\ub77c\ub294 \uac78 \uc0ac\uc6a9\ud574\uc694.\nBB\ud0c4\uc774 \ubb54\uc9c0 \uc544\ub098\uc694?", "start": 74.646, "duration": 4.904}, {"text": "\ub124. \uc800\ub3c4 \uc2ed \ub300 \ub0a8\uc790\uc560\ub4e4 \uadfc\ucc98\uc5d0 \uc788\uc5b4 \ubcf8 \uc801\uc774 \uc788\uc73c\ub2c8\nBB\ud0c4\uc774 \ubb54\uc9c0\ub294 \uc54c\uc8e0.", "start": 79.575, "duration": 4.333}, {"text": "\uadf8\ub7f0 \uc560\ub4e4\uacfc\ub294 \uac00\uae4c\uc774\ud558\uc9c0 \uc54a\ub294 \uac8c \uc88b\ub2e4\ub294 \uac83\ub3c4 \uc54c\uace0\uc694.\n\uc608\uc804\uc5d0\ub294 \uace0\uc591\uc774\ud55c\ud14c\ub3c4 \uc3d8\uace4 \ud588\ub294\ub370, \uc815\ub9d0 \ub054\ucc0d\ud588\uc5b4\uc694.", "start": 83.933, "duration": 4.447}, {"text": "\uace0\uc591\uc774\ub4e4\uc774 \uc120\uc0dd\ub2d8\ud55c\ud14c BB\ud0c4 \uc408\ub2e4\uace0\uc694?\n\ub9e8\uccb4\uc2a4\ud130\ub294 \uc815\ub9d0 \ud5d8\ud55c \ub3d9\ub124\ub124\uc694.", "start": 88.405, "duration": 7.498}, {"text": "\uc5ec\ub7ec\ubd84, \uadf8\ucabd\uc73c\ub85c \uac00\uc9c0 \ub9c8\uc138\uc694.\n\uc5b4\uca0c\ub4e0 \ubcfc \ubca0\uc5b4\ub9c1, BB\ud0c4\uc740 \uc5b4\ub5bb\uac8c \uc124\uba85\ud560 \uc218 \uc788\uc744\uae4c\uc694?", "start": 95.928, "duration": 6.548}, {"text": "\uc544\uc8fc \uc791\uc740\u2026", "start": 102.501, "duration": 0.879}, {"text": "\ud50c\ub77c\uc2a4\ud2f1 \ucd1d\uc54c\uc774\uc5d0\uc694.", "start": 103.405, "duration": 1.1}, {"text": "\uc791\ub514\uc791\uc740\u2026 \ud50c\ub77c\uc2a4\ud2f1\uc778\uac00\uc694?\n\uc804 \uae08\uc18d\uc778 \uc904 \uc54c\uc558\uc5b4\uc694.", "start": 104.53, "duration": 2.61}, {"text": "\uc544\ub2c8\uc5d0\uc694. \uc74c, \ud50c\ub77c\uc2a4\ud2f1\uc774\uc5d0\uc694.", "start": 107.14, "duration": 1.68}, {"text": "\uadf8\ub807\uad70\uc694. \uc6cc\ub099 \ube60\ub978 \uc18d\ub3c4\ub85c \ubc1c\uc0ac\ub418\uae30 \ub54c\ubb38\uc5d0\n\uc815\ub9d0\ub85c \ub2e4\uce60 \uc218\ub3c4 \uc788\uc5b4\uc694. \uadf8\ub807\uc8e0?", "start": 108.845, "duration": 4.385}, {"text": "\ubb3c\ub860\uc774\uc8e0. \ub208 \ubcf4\ud638 \uc7a5\ube44 \uac19\uc740 \uac78 \ud56d\uc0c1 \ucc29\uc6a9\ud574\uc57c \ud574\uc694.\n\uc800\ub294 \uc548\uacbd\uc744 \uc4f0\ub294\ub370, \uc774\uac74 \ubcf4\ud638 \uc7a5\ube44\ub294 \uc544\ub2c8\uace0\uc694.", "start": 113.255, "duration": 6.1}, {"text": "\ub354 \uc704\ud5d8\ud560 \uac83 \uac19\uc740\ub370\uc694. \ub208\uc55e\uc5d0 \uc720\ub9ac\uac00 \uc788\uc73c\ub2c8\uae4c\uc694.", "start": 119.38, "duration": 2.79}, {"text": "\ub9de\uc544\uc694. \uadf8\ub798\uc11c \ub354 \uc548\uc804\ud558\uac8c \ud558\ub824\uace0\n\uc81c \ub208\uc55e\uc5d0 \uc720\ub9ac\ub97c \ud55c \uacb9 \ub354 \ub367\ub314\uc5b4\uc694.", "start": 122.195, "duration": 5.688}, {"text": "\uadf8\ub9ac\uace0 \uc774 \ucd1d\ub4e4\uc740 \uac00\uc2a4\ub85c \uc791\ub3d9\ud574\uc694.", "start": 127.908, "duration": 2.772}, {"text": "\uc640.", "start": 130.705, "duration": 0.385}, {"text": "\uadf8\ub798\uc11c \uc2e4\uc81c \uc0b4\uc0c1 \uae30\uacc4\ub97c \ubcf8\ub72c \uc774 \ucd1d\uc744 \ub4e4\uace0\uc694.", "start": 131.09, "duration": 8.255}, {"text": "\uc0b4\uc0c1 \uae30\uacc4\ub77c\ub2c8.", "start": 139.37, "duration": 1.06}, {"text": "\ub124. \uadf8\ub9ac\uace0 \uc3d8\ub294 \uac70\uc608\uc694.\n\ubc29\uc544\uc1e0\ub97c \ub2f9\uaca8\uc11c \uc3d8\uba74 \uc555\ucd95\ub41c \uacf5\uae30\uac00 \ubd84\ucd9c\ub418\ub294\ub370\uc694.", "start": 140.455, "duration": 11.471}, {"text": "\uadf8\uac8c BB\ud0c4\uc744 \uc544\uc8fc \ube60\ub974\uac8c \ub0a0\ub824 \ubcf4\ub0b4\uc694.\n\uc5b4\uca0c\ub4e0 \uc800\ub294 \uc544\ub0b4\uc640 \ud568\uaed8,", "start": 151.951, "duration": 8.144}, {"text": "\ub610 \uc544\ub0b4\uc640 \uacbd\uc7c1\ud558\uac70\ub098 \ud63c\uc790\uc11c \uc18c\ucd1d\uacfc \uad8c\ucd1d\uc744 \uc0ac\uc6a9\ud574\n\uc0ac\uaca9\uc744 \ud588\ub294\ub370, \uc815\ub9d0 \uc7ac\ubc0c\uc5c8\uc5b4\uc694.", "start": 160.12, "duration": 6.965}, {"text": "\uba4b\uc9c0\ub124\uc694. \uc804 \uc0ac\uaca9\uc740 \uc548 \ud574\ubd24\uc9c0\ub9cc\n\uc591\uad81\uc744 \ud574 \ubd24\ub294\ub370, \uc815\ub9d0 \ub9c8\uc74c\uc5d0 \ub4e4\uc5c8\uc5b4\uc694.", "start": 167.11, "duration": 4.8}, {"text": "\uc774\uac74 \ud604\ub300 \ubc84\uc804\uc774\ub77c\uace0 \ud560 \uc218 \uc788\uc5b4\uc694.", "start": 171.935, "duration": 2.005}, {"text": "\uadf8\ub807\uad70\uc694.", "start": 173.965, "duration": 0.63}, {"text": "\ud604\ub300 \ubc84\uc804\uc758 \uc591\uad81\uc774\uc694. \uc800\ub3c4 \uc591\uad81\uc744 \ud574 \ubd24\ub294\ub370\uc694.\n\uc9d1\uc5d0 \uc591\uad81 \uc138\ud2b8\ub3c4 \uc788\ub294\ub370 \uac70\uc758 \uc0ac\uc6a9\ud558\uc9c0 \uc54a\uace0 \uc788\uc5b4\uc694.", "start": 174.62, "duration": 6.748}, {"text": "\uc0ac\uc2e4 \uc880 \uc368\uc57c \ud574\uc694. \ucee4\ub2e4\ub780 \uacfc\ub141\uc774\ub791 \ud544\uc694\ud55c \ubb3c\ud488\uc744\n\ub2e4 \uac00\uc9c0\uace0 \uc788\uac70\ub4e0\uc694. \uc591\uad81\uc744 \uc815\ub9d0 \uc88b\uc544\ud558\uae30\ub3c4 \ud558\uace0\uc694.", "start": 181.393, "duration": 6.557}, {"text": "\uc9d1\uc5d0 \uc591\uad81 \uc138\ud2b8\uac00 \uc788\ub2e4\uace0\uc694? \uad49\uc7a5\ud55c\ub370\uc694.", "start": 187.975, "duration": 2.22}, {"text": "\ub124. \uc544\ub9c8\uc874 \uac19\uc740 \ub370\uc11c 10\ud30c\uc6b4\ub4dc \uc8fc\uace0 \uc0b0 \uac70\uc608\uc694.", "start": 190.22, "duration": 3.58}, {"text": "\uc815\ub9d0\uc694?", "start": 193.825, "duration": 0.436}, {"text": "\ub124.", "start": 194.261, "duration": 0.419}, {"text": "\uc6b0\uc640.", "start": 194.68, "duration": 0.725}, {"text": "\ube44\uc2f8\uc9c0 \uc54a\ub2f5\ub2c8\ub2e4. \uc9c4\uc9dc \ud654\uc0b4\uc774 \uc544\ub2c8\uac70\ub4e0\uc694.\n\ud654\uc0b4 \ub05d\uc5d0 \uace0\ubb34 \ud761\ucc29\ud310 \uac19\uc740 \uac8c \ub2ec\ub9b0 \uac70\uc608\uc694.", "start": 195.43, "duration": 7.38}, {"text": "\uc544, \uadf8\ub807\uad70\uc694.", "start": 202.81, "duration": 0.69}, {"text": "\uadf8\ub798\ub3c4 \ud06c\ub9ac\uc2a4\ub9c8\uc2a4 \ub54c \uadf8\uac78 \ubc1b\uc558\uc744 \ub54c,\n\uac00\uc871 \uc804\uccb4\uac00 \uadf8\uac78 \uac00\uc9c0\uace0 \ub180\uc558\ub294\ub370 \uc544\uc8fc \uc7ac\ubc0c\uc5c8\uc5b4\uc694.", "start": 203.5, "duration": 7.617}, {"text": "\uc138\uc0c1\uc5d0, \uc815\ub9d0 \uc7ac\ubc0c\uc5c8\uaca0\ub124\uc694.", "start": 211.142, "duration": 1.003}, {"text": "\uc544\uc8fc \uc88b\uc558\uc8e0. \ub2e4\uc74c\uc5d0 \ud574 \ubcf4\uc2dc\uae38 \ucd94\ucc9c\ud560\uac8c\uc694.", "start": 212.17, "duration": 2.642}, {"text": "\ud559\uc0dd \uc5ec\ub7ec\ubd84\ub4e4\ub3c4 \ubaa8\ub4e0 \uac78 \ub2e4 \uac00\uc9c4 \uc9c0\uc778\uc5d0\uac8c \uc904\n\uc120\ubb3c\uc744 \ucc3e\uace0 \uc788\ub2e4\uba74, \uc591\uad81 \uc138\ud2b8\ub97c \ucd94\ucc9c\ud569\ub2c8\ub2e4.", "start": 214.837, "duration": 7.553}, {"text": "\ub2e4\ub77d\ubc29\uc5d0\uc11c \uba3c\uc9c0\ub9cc \uc313\uc774\uaca0\uad70\uc694.", "start": 222.415, "duration": 2.52}, {"text": "\uadf8\ub7fc\uc694. \uc790, \uc624\ub298\ub3c4 \n'This'\uc640 'That'\uc774 \uac01\uac01 \uc900\ube44\ub418\uc5b4 \uc788\ub294\ub370\uc694.", "start": 224.96, "duration": 6.86}, {"text": "'This'\ub294 \uc9d1\uc5d0\uc11c \uc694\ub9ac\ud558\uae30\uc774\uace0, 'That'\uc740 \uae34 \ud558\ub8e8\ub97c\n\ubcf4\ub0b8 \ub4a4 \ubc30\ub2ec \uc74c\uc2dd\uc744 \uc2dc\ucf1c \uba39\uac70\ub098 \uc678\uc2dd\ud558\uae30\uc785\ub2c8\ub2e4.", "start": 231.845, "duration": 12.36}, {"text": "\ub124.", "start": 244.23, "duration": 0.445}, {"text": "\uba3c\uc800 \uc774\uac78 \ud574 \ubcfc\uae4c\uc694?\n\ub2e4\ub978 \uc0ac\ub78c\uc774 \uc5b4\ub5a4 \uac78 \uace8\ub790\uc744\uc9c0 \ub9de\ud600\ubcf4\ub294 \ubc29\uc2dd\uc774 \ub098\uc654\uc5c8\uc8e0.", "start": 244.675, "duration": 6.11}, {"text": "\ub9de\uc544\uc694.", "start": 250.785, "duration": 0.48}, {"text": "\uc774\uac74 \uc5b4\ub835\uc9c0 \uc54a\uc744 \uac83 \uac19\uc544\uc694.", "start": 251.265, "duration": 1.92}, {"text": "\uadf8\ub7ec\uac8c\uc694.", "start": 253.185, "duration": 0.5}, {"text": "\uadf8\ub7fc \uc81c\uac00 \ubb58 \uace8\ub790\uc744\uc9c0 \uc120\uc0dd\ub2d8\uc774 \ub9de\ucdb0\ubcf4\uc2dc\uaca0\uc5b4\uc694?", "start": 253.695, "duration": 4.11}, {"text": "\ub124. \uc120\uc0dd\ub2d8\uc740 \uc9d1\uc5d0\uc11c \uba39\ub294 \uac78 \uace8\ub790\uc744 \uac83 \uac19\uc544\uc694.", "start": 257.805, "duration": 2.25}, {"text": "\uc804\ud600 \uc544\ub2d9\ub2c8\ub2e4. \uc808\ub300\ub85c\uc694.", "start": 260.055, "duration": 1.56}, {"text": "\uc815\ub9d0\uc694?", "start": 261.64, "duration": 0.785}, {"text": "\uc804\ud600 \uc544\ub2c8\uc5d0\uc694. \uc65c\ub0d0\ud558\uba74 \ud56d\uc0c1 \uadf8\ub807\uac8c \ud558\uace0 \uc788\uac70\ub4e0\uc694.\n\uadf8\ub798\uc11c \ub354 \ud765\ubbf8\ub85c\uc6b4 \ucabd\uc744 \uace8\ub790\uc5b4\uc694.", "start": 262.45, "duration": 5.926}, {"text": "\uc544\ub2c8, \uc0ac\uc2e4 \uadf8\ub0e5 \ubc18\ub300 \uc758\uacac\uc744 \ub9d0\ud574 \ubcf4\ub824\uace0 \ud55c \uac70\uace0\uc694.\n\uc0ac\uc2e4 \uac70\uc758 \ud56d\uc0c1 \uc9d1\uc5d0\uc11c \ud574 \uba39\ub294\ub2f5\ub2c8\ub2e4.", "start": 268.401, "duration": 7.644}, {"text": "\uc74c, \uc800\ub3c4 \uadf8\ub798\uc694.", "start": 276.07, "duration": 1.14}, {"text": "\ub9de\uc544\uc694. \ubc14\ubcf4 \uac19\uc740 \uc9c8\ubb38\uc744 \ud558\ub098 \ud560\uac8c\uc694.\n\uc65c \uc6b0\ub9ac\ub294 \ud56d\uc0c1 \uc9d1\uc5d0\uc11c \uc694\ub9ac \ud574 \uba39\uc744\uae4c\uc694?", "start": 277.24, "duration": 6.831}, {"text": "\uc65c \ub9e4\uc77c \uc678\uc2dd\ud558\uac70\ub098 \ubc30\ub2ec \uc74c\uc2dd\uc744 \uba39\uc9c0 \uc54a\ub294 \uac78\uae4c\uc694?", "start": 284.096, "duration": 4.654}, {"text": "\ub3c8, \ub3c8, \ub3c8. \uadf8\uac8c \uc774\uc720\uc5d0\uc694.", "start": 288.775, "duration": 2.375}, {"text": "\ub9de\uc544\uc694.", "start": 291.175, "duration": 1.2}, {"text": "\ubb3c\ub860 \uac00\ub054 \uc678\uc2dd\ud558\ub294 \uac74 \uc88b\uc544\ud574\uc694.\n\uc81c\uac00 \uc774 \uc8fc\uc81c\uc5d0 \ub300\ud574 \ud560 \uc598\uae30\uac00 \ub9ce\uc740 \uac83 \uac19\ub124\uc694.", "start": 292.375, "duration": 6.135}, {"text": "\uc0ac\uc2e4 \uc608\uc804\ub9cc\ud07c \uc694\ub9ac\ub3c4 \uc790\uc8fc \ud558\uc9c0\ub294 \uc54a\ub294\ub370\uc694.\n\uc694\ub9ac\ub97c \uc815\ub9d0 \uc88b\uc544\ud558\uae34 \ud558\uc9c0\ub9cc \uc2dc\uac04\uc744 \uc6cc\ub099 \ub9ce\uc774 \uc7a1\uc544\uba39\uac70\ub4e0\uc694.", "start": 298.535, "duration": 5.165}, {"text": "\uadf8\ub9ac\uace0 \ub2f9\uc5f0\ud788 \ud798\ub4e0 \ud558\ub8e8\ub97c \ubcf4\ub0c8\uc744 \ub54c, \ud2b9\ud788 \uc544\uc774\uac00 \uc788\uac70\ub098\n\ucd9c\ud1f4\uadfc\uc744 \ud558\ub294 \uc0ac\ub78c\uc774\ub77c\uba74", "start": 303.725, "duration": 6.308}, {"text": "\ubc30\ub2ec \uc74c\uc2dd\uc744 \uba39\ub294 \uac8c \ucd5c\uace0\uc758 \uc120\ud0dd\uc77c \uac70\uc608\uc694.\n\uadf8\ub7f0\ub370 \uac1c\uc778\uc801\uc73c\ub85c\ub294 \uadf8\uac8c \uadf8\ub2e4\uc9c0 \ud3b8\ub9ac\ud558\ub2e4\uace0 \ub290\ub07c\uc9c0 \uc54a\uc544\uc694.", "start": 310.058, "duration": 7.633}, {"text": "\uc2b5\uad00\ucc98\ub7fc \ud558\uace0 \uc788\uc5b4\uc11c \uc774\ubbf8 \uc571\uc774 \uae54\ub824\uc788\uace0, \uce74\ub4dc \uc815\ubcf4\ub3c4\n\uc785\ub825\ub418\uc5b4 \uc788\uace0, \ubb58 \uc8fc\ubb38\ud560\uc9c0 \uc798 \uc54c\uace0 \uc788\ub2e4\uba74 \uc0c1\uad00\uc5c6\uaca0\uc8e0.", "start": 317.716, "duration": 9.337}, {"text": "\ud558\uc9c0\ub9cc \uc74c\uc2dd\ub3c4 \uace8\ub77c\uc57c \ud558\uace0, \uae30\ub2e4\ub824\uc57c \ud558\uace0, \ub610 \uc81c\uac00\n\uc7ac\ud65c\uc6a9\uc5d0 \uc9d1\ucc29\ud558\ub294 \ud3b8\uc774\ub77c \uadf8\ub0e5 \ubc84\ub9ac\ub294 \uc77c\uc774 \uc5c6\uac70\ub4e0\uc694.", "start": 327.078, "duration": 7.007}, {"text": "\ud50c\ub77c\uc2a4\ud2f1 \uc6a9\uae30\ub97c \uc804\ubd80 \ub2e4 \ud5f9\uad70 \ub2e4\uc74c\n\uc7ac\ud65c\uc6a9 \uc218\uac70\ud568\uc5d0 \ub123\uc5b4\uc57c \ud558\uc8e0.", "start": 334.11, "duration": 5.203}, {"text": "\uadf8\ub798\uc11c \uc194\uc9c1\ud788 \uc694\ub9ac\ud558\ub294 \uac83\ubcf4\ub2e4\n\uadf8\ub807\uac8c \ud3b8\ud55c\uc9c0\ub3c4 \ubaa8\ub974\uaca0\ub354\ub77c\uace0\uc694.", "start": 339.338, "duration": 5.002}, {"text": "\uc774\ud574\uac00 \ub418\ub124\uc694.\n\uc800\ub294 \ubc30\ub2ec \uc74c\uc2dd\uc758 \ud3b8\ub9ac\uc131\uc5d0 \ub300\ud574 \uc0dd\uac01\ud574 \ubcf8 \uc801\uc740 \uc5c6\ub294\ub370\uc694.", "start": 344.365, "duration": 6.02}, {"text": "\uc804\uc5d0 \uc544\ub0b4\uc5d0\uac8c \uc774\ub7f0 \uc598\uae30\ub97c \ud55c \uc801\uc740 \uc788\uc5b4\uc694.\n\uc774\uc0c1\ud558\uac8c\ub3c4 \uc678\uc2dd\ud558\ub7ec \ub098\uac00\ub294 \uac8c \uaf64 \uc218\uace0\uac00 \ub9ce\uc774 \ub4e0\ub2e4\uace0\uc694.", "start": 350.41, "duration": 8.615}, {"text": "\ub9de\uc544\uc694.", "start": 359.05, "duration": 0.4}, {"text": "\uc544\ub0b4\uc5d0\uac8c \uc774\ub807\uac8c \ub9d0\ud588\uc5c8\uc5b4\uc694.\n\uc6b0\ub9ac\uac00 \ud53c\uace4\ud55c \ub0a0\uc774\uba74 \"\uc544, \ub108\ubb34 \ud53c\uace4\ud558\ub2e4. \uc694\ub9ac\ud558\uae30 \uc2eb\uc5b4.", "start": 359.45, "duration": 7.075}, {"text": "\ub0c9\uc7a5\uace0\uae4c\uc9c0 \uac00\uc57c \ud558\uace0, \ub0c9\uc7a5\uace0\uc5d0\uc11c \ubb54\uac00\ub97c \uaebc\ub0b4\uc11c\n\ud55c\ucabd\uc5d0 \uc62c\ub824\ub194\uc57c \ud558\uace0, \uc800\uac83\ub3c4 \ud558\uace0\u2026\"\ub77c\uace0 \uc0dd\uac01\ud55c\ub2e4\uace0\uc694.", "start": 366.55, "duration": 9.491}, {"text": "\uadf8\ub7f0\ub370 \uc774\uc0c1\ud558\uac8c\ub3c4 \uc81c\uac00 \"20\ubd84 \uac78\uc5b4\uc11c \ub808\uc2a4\ud1a0\ub791\uc5d0 \uac00\uace0,\n\uac70\uae30\uc11c \uae30\ub2e4\ub9ac\uace0, \ub610 20\ubd84 \uac78\ub824\uc11c \ub3cc\uc544\uc624\ub294 \uac74 \uc5b4\ub54c?\"", "start": 376.066, "duration": 8.204}, {"text": "\uc774\ub7f0 \uc598\uae30\ub97c \ud558\uba74 \ud56d\uc0c1 \"\uc624 \uadf8\uac70 \uc544\ubb34\ub7f0 \ub178\ub825\ub3c4 \ud544\uc694\uc5c6\uaca0\ub124.\n\uadf8\ub807\uac8c \ud558\uc790!\"\ub77c\uace0 \ud55c\ub2e4\uace0 \ud588\uc5b4\uc694.", "start": 384.295, "duration": 3.68}, {"text": "\ub9c8\uce58 \ubab0\uc544\uc11c \ubcf4\ub294 \uac83\uacfc \ube44\uc2b7\ud558\uc9c0 \uc54a\ub098\uc694?\n\ub204\uad70\uac00\uc5d0\uac8c \"2\uc2dc\uac04\uc9dc\ub9ac \uc601\ud654\ub97c \ubcfc\ub798\uc694?\"\ub77c\uace0 \ubb3c\uc5b4\ubcf4\uba74", "start": 388.0, "duration": 5.574}, {"text": "\"\uc544\ub1e8, \uadf8\ub7f4 \uc2dc\uac04\uc774 \uc5c6\uc5b4\uc694\"\ub77c\uace0 \ub9d0\ud558\uac70\ub4e0\uc694.", "start": 393.605, "duration": 2.045}, {"text": "\uadf8\ub7f0\ub370 \uc815\uc2e0\ub3c4 \ubabb \ucc28\ub9ac\uace0 \ub4dc\ub77c\ub9c8\ub97c \uc5f0\ub2ec\uc544\uc11c\n4\uc2dc\uac04 \ub3d9\uc548 \ubcf4\uaca0\ub290\ub0d0\uace0 \ubb3b\ub294\ub2e4\uba74,", "start": 395.675, "duration": 5.672}, {"text": "\uadf8\uac8c \uc6b0\ub9ac\uac00 \ud558\ub294 \uc77c\uc774\uac70\ub4e0\uc694. \uac19\uc740 \uac70\uc608\uc694.", "start": 401.372, "duration": 1.604}, {"text": "\uadf8\ub7fc\uc694. \uadf8\ub798\uc11c \uc800\ub294 \ub3c8\uc774 \ud070 \uc774\uc720\ub77c\uace0 \uc0dd\uac01\ud574\uc694.\n\ud55c\uad6d\uc5d0 \ub300\ud574 \uc798 \uc544\ub294 \uac74 \uc544\ub2c8\uc9c0\ub9cc,", "start": 403.0, "duration": 7.131}, {"text": "\uc81c\uac00 \uc544\ub294 \ubc14\uc5d0 \ub530\ub974\uba74 \ud55c\uad6d\uc740 \ubc30\ub2ec \uc74c\uc2dd\uc744 \uba39\uac70\ub098\n\uc678\uc2dd\ud558\ub294 \uac8c \ud6e8\uc52c \uc800\ub834\ud558\ub2e4\uace0 \ud558\ub354\ub77c\uace0\uc694.", "start": 410.156, "duration": 5.719}, {"text": "\uc2dc\uc2a4\ud15c\ub3c4 \ub354 \uc88b\uc544\uc694.\n\ud55c\uad6d\uc5d0\ub294 \uc774\ub7f0 \uc11c\ube44\uc2a4\ub3c4 \uc788\ub2e4\ub294 \uac83 \uac19\uc544\uc694.", "start": 415.9, "duration": 3.869}, {"text": "\ubaa8\ub4e0 \uac8c \ub9cc\ub4e4\uc5b4\uc9c4 \ucc44\ub85c \ubc30\ub2ec\ub3fc\uc11c\n\uadf8\ub0e5 \ub0c4\ube44\uc5d0 \ub123\uae30\ub9cc \ud558\uba74 \ub41c\ub300\uc694.", "start": 419.794, "duration": 5.386}, {"text": "\uadf8\ub9ac\uace0 \uc6a9\uae30 \uac19\uc740 \uac78 \ubb38\ubc16\uc5d0 \uac16\ub2e4 \ub193\uc73c\uba74\n\ub098\uc911\uc5d0 \uc640\uc11c \uac00\uc838\uac00\uace0\uc694.", "start": 425.205, "duration": 3.422}, {"text": "\uc0ac\ub78c\ub4e4\uc740 \uc601\uad6d\uc5d0\uc11c\uc758 \uc678\uc2dd\uc774 \uc5bc\ub9c8\ub098 \ube44\uc2fc \uac74\uc9c0\n\uc798 \ubaa8\ub974\ub294 \uac83 \uac19\uc544\uc694.", "start": 428.652, "duration": 4.46}, {"text": "\uc81c\uac00 \ub3c8\uc744 \uc4f0\uae30 \uc2eb\uc5b4\uc11c \uc774\ub7ec\ub294 \uac74 \uc544\ub2c8\uace0\uc694.\n\uadf8\ub807\uac8c \uc778\uc0c9\ud558\uc9c0\ub294 \uc54a\uac70\ub4e0\uc694.", "start": 433.137, "duration": 2.826}, {"text": "\uadf8\uc800 \uac00\ub054\uc740 \uadf8\ub9cc\ud55c \uac00\uce58\uac00 \uc788\ub294\uc9c0 \uc798 \ubaa8\ub974\uaca0\ub354\ub77c\uace0\uc694.", "start": 435.988, "duration": 3.261}, {"text": "\ub0b4\uac00 \uc815\ub9d0 \uc88b\uc544\ud558\ub294 \uc74c\uc2dd\uc774\uac70\ub098\n\uc544\uc8fc \uc798 \ub9cc\ub4e0 \uac8c \uc544\ub2c8\ub77c\uba74 \ub9d0\uc774\uc5d0\uc694.", "start": 439.274, "duration": 4.036}, {"text": "\uc81c\uac00 \uc815\ud655\ud558\uac8c \uc544\ub294 \uac74 \uc544\ub2cc\ub370\uc694.\n\uadf8\ub0e5 \uc81c\uac00 \ub4e4\uc740 \uac74\ub370,", "start": 443.335, "duration": 5.519}, {"text": "\uc601\uad6d\uc5d0 \uc788\ub294 \ub808\uc2a4\ud1a0\ub791\uc5d0 \uac00\uba74 \uc9c0\ubd88\ud558\ub294 \ub3c8\uc758\n1/3\ub9cc \uc2e4\uc81c \uc74c\uc2dd\uac12\uc774\ub77c\uace0 \ud558\ub354\ub77c\uace0\uc694.", "start": 448.879, "duration": 7.85}, {"text": "\ub098\uba38\uc9c0 \ub0b4\ub294 \ub3c8\uc758 2/3\uc5d0\uc11c 1/3\uc774 \uc9c1\uc6d0\ub4e4 \uae09\uc5ec\uace0,\n\ub098\uba38\uc9c0\uac00\u2026", "start": 456.754, "duration": 9.161}, {"text": "\uc800\ub3c4 \ub9c8\uc9c4\uc774 \uc788\ub2e4\uace0 \uc54c\uace0 \uc788\uc5b4\uc694.", "start": 465.94, "duration": 1.175}, {"text": "\ub9c8\uc9c4\uc778\ub370\uc694. \uadf8 \uc548\uc5d0 \ub808\uc2a4\ud1a0\ub791\uc774 \uc704\uce58\ud55c \uac74\ubb3c\uc744 \uc6b4\uc601\ud558\ub294\n\ubaa8\ub4e0 \ube44\uc6a9\ub3c4 \ud3ec\ud568\ub3fc \uc788\uc5b4\uc694. \uc804\uae30, \uac00\uc2a4 \uac19\uc740 \uac83\ub4e4\uc774\uc694.", "start": 467.14, "duration": 9.684}, {"text": "\uadf8\ub7ec\ub2c8 \uc21c\uc218\ud558\uac8c \ub3c8\uc758 \uad00\uc810\uc5d0\uc11c\ub9cc \ubcf8\ub2e4\uba74,\n\uc678\uc2dd\uc740 \uadf8 \uac12\uc5b4\uce58\ub97c \ud558\uc9c0 \ubabb\ud55c\ub2e4\uace0 \uc8fc\uc7a5\ud560 \uc218 \uc788\uc5b4\uc694.", "start": 476.849, "duration": 9.315}, {"text": "\uc804\ud600 \uc544\ub2c8\uc8e0.", "start": 486.189, "duration": 0.561}, {"text": "\ub124.", "start": 486.775, "duration": 0.415}, {"text": "\uc74c\uc2dd\uc744 \uba39\uae30 \uc704\ud574\n\uc0ac\uc2e4\uc0c1 \ud544\uc694\ud55c \uae08\uc561\uc758 \uc138 \ubc30\ub97c \ub0b4\ub294 \uc148\uc774\ub2c8\uae4c\uc694.", "start": 487.19, "duration": 6.346}, {"text": "\ud558\uc9c0\ub9cc \uc81c \uce5c\uad6c\ub4e4\uc774 \uc5ec\uae30\uc5d0 \ub300\ud574\n\uc800\uc5d0\uac8c \uc9c0\uc801\ud55c \ub0b4\uc6a9\uc774 \uc788\ub294\ub370\uc694.", "start": 493.536, "duration": 3.703}, {"text": "\ub3c8\uc744 \ub0b4\ub294 \uac8c \uaf2d \uc74c\uc2dd \ub54c\ubb38\ub9cc\uc740 \uc544\ub2c8\ub780 \uac70\uc608\uc694.\n\uc74c\uc2dd\ub3c4 \uc788\uc9c0\ub9cc, \uc678\uc2dd\uc758 \uc9c4\uc9dc \uac00\uce58\ub294\u2026", "start": 497.264, "duration": 5.401}, {"text": "\ubd84\uc704\uae30\uc8e0.", "start": 502.69, "duration": 0.9}, {"text": "\ubd84\uc704\uae30\uc608\uc694. \ud568\uaed8 \uc628 \uc0ac\ub78c\uacfc \ub300\ud654\ub97c \ub098\ub20c \uae30\ud68c\ub3c4 \uc0dd\uae30\uace0\uc694.", "start": 503.59, "duration": 6.255}, {"text": "\ub124. \uc0ac\uad50 \ud65c\ub3d9\uc774\uc8e0. \uc800\ub3c4 \uc774 \uc0dd\uac01\uc744 \uc790\uc8fc \ud558\ub294\ub370\uc694.", "start": 509.87, "duration": 3.189}, {"text": "\uc81c\uac00 Subway Takes\ub77c\ub294 \uc720\ud29c\ube0c \ucc44\ub110\uc5d0 \ub300\ud574\n\uc598\uae30\ud55c \uc801 \uc788\uc796\uc544\uc694.", "start": 513.084, "duration": 3.052}, {"text": "\uc5b4\ub5a4 \ub0a8\uc790\uac00 \ub098\uc640\uc11c \ub17c\ub780\uc774 \ub9ce\uc740 \uc8fc\uc81c\uc5d0 \ub300\ud55c\n\uc758\uacac\uc744 \ubb3b\ub294 \uac70\uc694.", "start": 516.161, "duration": 4.283}, {"text": "\uc81c \uc758\uacac\uc744 \ub9d0\uc500\ub4dc\ub9ac\uc790\uba74 \uc0ac\uc2e4 \uc804 \ucc2c\uc131\ud558\uc9c0 \uc54a\uc544\uc694.\n\ubb3c\ub860 \uc800\ub3c4 \uc678\uc2dd\uc744 \uc88b\uc544\ud574\uc694. \ub204\uac00 \uc548 \uc88b\uc544\ud558\uaca0\ub098\uc694?", "start": 520.469, "duration": 5.904}, {"text": "\ud558\uc9c0\ub9cc \uc678\uc2dd\uc774\ub098 \uc220 \ub9c8\uc2dc\ub7ec \ub098\uac00\ub294 \uac74\n\uacbd\uc81c\uc801\uc73c\ub85c \ubcf4\uba74 \ub9d0\ub3c4 \uc548 \ub418\ub294 \ud589\ub3d9\uc774\uc5d0\uc694.", "start": 526.398, "duration": 3.528}, {"text": "\uc6cc\ub099 \uc775\uc219\ud574\uc838\uc11c \uae68\ub2eb\uc9c0 \ubabb\ud558\ub294 \uac83\ubfd0\uc774\uc9c0,\n\ub0b4\ub294 \ub3c8\uc744 \uc0dd\uac01\ud558\uba74 \uc815\ub9d0 \uc5c4\uccad\ub098\uac70\ub4e0\uc694.", "start": 529.951, "duration": 6.668}, {"text": "\uc81c\ub300\ub85c \uc549\uc544\uc11c \uacc4\uc0b0\ud574 \ubcf4\uace0 \ub9c8\ud2b8\uc5d0\uc11c \uc0ac\ub294 \uc2dd\uc7ac\ub8df\uac12\uacfc\n\ube44\uad50\ud574 \ubcf4\uba74 \ub9d0\ub3c4 \uc548 \ub418\ub294 \uc218\uc900\uc774\uc5d0\uc694.", "start": 536.644, "duration": 7.86}, {"text": "\uadf8\ub807\ub2e4\uace0 \ud574\uc11c \uc678\uc2dd\uc744 \ud558\uc9c0 \ub9d0\uc790\ub294 \ub9d0\uc740 \uc544\ub2cc\ub370\uc694.", "start": 544.529, "duration": 1.43}, {"text": "\uc678\uc2dd\uc744 \uc804\ud600 \ud558\uc9c0 \uc54a\uace0 \ubc16\uc5d0 \ub098\uac00\uc9c0\ub3c4 \uc54a\uc73c\uba74\n\uc0ac\ud68c\uc801\uc73c\ub85c \uad49\uc7a5\ud788 \uace0\ub9bd\ub420 \ud14c\ub2c8\uae4c\uc694.", "start": 545.984, "duration": 4.796}, {"text": "\ub9de\uc544\uc694. \uc815\ub9d0 \uadf8\ub798\uc694. \uadf8\ub9ac\uace0 \uc88b\uc740 \uc0ac\ub78c\ub4e4\uacfc \uc5b4\uc6b8\ub9ac\ub294 \uac74\n\uc5c4\uccad\ub09c \uac00\uce58\uac00 \uc788\ub2e4\uace0\ub3c4 \ub9d0\ud560 \uc218 \uc788\uc8e0.", "start": 550.805, "duration": 9.903}, {"text": "\uc81c\uac00 \uc790\uc8fc \ud558\uc9c0\ub294 \uc54a\uc9c0\ub9cc \uc88b\uc544\ud558\ub294 \ubc29\uc2dd\uc774 \uc788\ub294\ub370\uc694.", "start": 560.733, "duration": 4.115}, {"text": "\uc800\ub294 \uce5c\uad6c\ub4e4\uc744 \uc9d1\uc73c\ub85c \uc9c1\uc811 \ucd08\ub300\ud574\uc11c\n\uc694\ub9ac\ud574 \uc8fc\ub294 \uac78 \ud6e8\uc52c \ub354 \uc120\ud638\ud574\uc694.", "start": 564.873, "duration": 7.003}, {"text": "\ubb3c\ub860 \ub354 \ud070 \ub178\ub825\uc774 \ud544\uc694\ud558\uaca0\uc9c0\ub9cc,\n\uc9d1\uc5d0\uc11c \uc900\ube44\ud558\uba74 \uc6d0\ud558\ub294 \ub300\ub85c \ub2e4 \ud560 \uc218 \uc788\uac70\ub4e0\uc694.", "start": 571.901, "duration": 11.861}, {"text": "\ub9cc\uc57d \ub2e4 \uac19\uc774 \"\uc774\uc81c \ub098\uac00\uc11c \ub2e4\ub978 \uac78 \ud558\uc790\"\ub77c\uace0 \uacb0\uc815\ud55c\ub2e4\uba74,\n\uadf8\uac74 \ub808\uc2a4\ud1a0\ub791\uc5d0\uc11c\ub294 \ud560 \uc218 \uc5c6\ub294 \uc77c\uc774\uc8e0.", "start": 583.787, "duration": 7.915}, {"text": "\uc9d1\uc5d0\uc11c\ub294 \uc544\uc8fc \uc2dc\ub044\ub7fd\uac8c \ub180\uac70\ub098\n\uc0ac\ud68c\uc801\uc73c\ub85c \ubd80\uc801\uc808\ud55c \ud589\ub3d9\uc744 \ud560 \uc218\ub3c4 \uc788\uc5b4\uc694.", "start": 591.727, "duration": 4.778}, {"text": "\ubb3c\ub860 \uadf8\ub7ec\uba74 \uc548 \ub418\uc9c0\ub9cc\uc694.\n\uc800\ub294 \ub808\uc2a4\ud1a0\ub791\uc5d0\uc11c\ub3c4 \uadf8\ub7ec\uae30\ub294 \ud558\ub294\ub370 \ud558\uba74 \uc548 \ub420 \uac83 \uac19\ub124\uc694.", "start": 596.53, "duration": 4.225}, {"text": "\uc9c0\uae08 \ub5a0\uc624\ub978 \uadf8\ub9bc\uc774 \uc788\ub294\ub370\uc694.\n\uc644\ubcbd\ud55c \uc608\uc2dc\ub77c\uace0 \ubcfc \uc218 \uc788\uc5b4\uc694.", "start": 600.78, "duration": 3.015}, {"text": "\uc81c\uac00 \ucc98\uc74c\uc73c\ub85c \ud63c\uc790 \uc0ac\ub294 \uc790\ucde8\ubc29\uc5d0 \uc774\uc0ac\ud588\uc744 \ub54c\uc600\uc5b4\uc694.\n\uc544\uc8fc \uad49\uc7a5\ud55c \uc77c\uc774\uc5c8\uc8e0. \"\uc774\uac70 \ucd5c\uace0\ub2e4\"\ub77c\uace0 \uc0dd\uac01\ud588\uc5b4\uc694.", "start": 603.82, "duration": 6.226}, {"text": "\uadf8\ub9ac\uace0 \uce5c\uad6c\ub97c \ucd08\ub300\ud574\uc11c \uc9c1\uc811 \uc694\ub9ac\ub97c \ud574 \uc92c\ub294\ub370,\n\ubc14\ub85c \uadf8\ub7f0 \uacbd\ud5d8\uc744 \ud588\uc5b4\uc694.", "start": 610.071, "duration": 5.32}, {"text": "\ubd88\uc744 \ub044\uace0\uc11c\ub294 \uc0c9\uae54\uc774 \uc788\ub294 \uc870\uba85\uc744 \ucf30\ub294\ub370\uc694.\n\uc81c\uac00 \ubc24\uc5d0 \ubd89\uc740 \uc870\uba85\uc744 \ucf1c\uace0 \uc788\ub294 \uac78 \uc815\ub9d0 \uc88b\uc544\ud558\uac70\ub4e0\uc694.", "start": 615.416, "duration": 5.492}, {"text": "\ub208\uc744 \uc544\uc8fc \ud3b8\uc548\ud558\uac8c \ud574 \uc8fc\uc8e0.\n\uadf8\ub7f0\ub370 \uadf8\uac83 \ub9d0\uace0 \ub2e4\ub978 \uc0c9\uae54\ub3c4 \uc120\ud0dd\ud560 \uc218 \uc788\uc5c8\uc5b4\uc694.", "start": 620.933, "duration": 3.338}, {"text": "\ubd84\ud64d\uc0c9\ub3c4 \uc788\uace0, \ucd08\ub85d\uc0c9\ub3c4 \uc788\uc5c8\uc8e0.\n\ubab0\ub790\ub294\ub370 \ub514\uc2a4\ucf54 \uc635\uc158 \uac19\uc740 \uac83\ub3c4 \uc788\ub354\ub77c\uace0\uc694.", "start": 624.296, "duration": 3.246}, {"text": "\uc0c9\uae54\uc774 \uacc4\uc18d \ubc14\ub00c\ub294 \uc870\uba85\uc774\uc5c8\ub294\ub370, \uadf8\uac74 \uacb0\uad6d\uc5d4 \uc2a4\ud2b8\ub808\uc2a4\uae34\n\ud588\uc5b4\uc694. \uc5b4\uca0c\ub4e0 \uadf8 \uc870\uba85\uc744 \ucf1c \ub193\uc558\uc8e0.", "start": 627.567, "duration": 5.027}, {"text": "\uc120\uc0dd\ub2d8\ub3c4 \uc54c\ub2e4\uc2dc\ud53c \uc81c\uac00 \uc74c\uc545\uc744 \uc815\ub9d0 \uc88b\uc544\ud558\uc796\uc544\uc694.\n\uc74c\uc545\uc774 \uc800\ud55c\ud14c\ub294 \uc815\ub9d0 \uc911\uc694\ud574\uc694.", "start": 632.619, "duration": 4.607}, {"text": "\uc74c\uc545\uc744 \ud2c0\uace0, \uc81c\uac00 \uc9c1\uc811 \ud50c\ub808\uc774\ub9ac\uc2a4\ud2b8\ub3c4 \ub9cc\ub4e4\uc5b4\uc11c\n\uac70\uc2e4\uc5d0\uc11c \ucda4\uc744 \ucd94\uae30 \uc2dc\uc791\ud588\uc5b4\uc694.", "start": 637.251, "duration": 5.269}, {"text": "\uadf8\ub9ac\uace0 \uc81c\uac00 \uce5c\uad6c\uc5d0\uac8c \ubc14\ub85c \uc774\ub807\uac8c \ub9d0\ud55c \uae30\uc5b5\uc774 \ub098\uc694.", "start": 642.545, "duration": 2.632}, {"text": "\"\uc6b0\ub9ac\uac00 \ub808\uc2a4\ud1a0\ub791\uc5d0 \uc788\uc5c8\ub2e4\uba74 \n\uc774\ub7f0 \uac74 \ud558\uc9c0 \ubabb\ud588\uc744 \uac70\uc57c\"\ub77c\uace0\uc694. \uc815\ub9d0 \uae30\ubd84\uc774 \uc88b\uc558\uac70\ub4e0\uc694.", "start": 645.202, "duration": 4.185}, {"text": "\"\uc5ec\uae30\uc11c\ub294 \uadf8\ub0e5 \uc6b0\ub9ac\uac00 \uc6d0\ud558\ub294 \ub300\ub85c \ud560 \uc218 \uc788\ub124\"\n\ub77c\uace0 \uc0dd\uac01\ud588\uc5b4\uc694.", "start": 649.412, "duration": 2.002}, {"text": "\uadf8\ub7f0\ub370 \uadf8\ub0a0 \ubc24\uc5d0 \uc81c\uac00 \ub610 \ubb58 \ud588\ub294\uc9c0 \uc544\uc138\uc694?\n\uc0c8\ubcbd 2\uc2dc\uae4c\uc9c0 \uc7a0\ub3c4 \ubabb \uc790\uace0 \uc124\uac70\uc9c0\ub97c \ud574\uc57c \ud588\ub2f5\ub2c8\ub2e4.", "start": 651.439, "duration": 5.536}, {"text": "\uc778\uc0dd\uc740 \uc624\ub974\ub9c9\uacfc \ub0b4\ub9ac\ub9c9\uc774 \ub2e4 \uc788\ub294 \ubc95\uc774\uc8e0.", "start": 657.0, "duration": 2.76}, {"text": "\uc81c\uac00 \uc9c4\uc9dc \uc815\uc131\uc744 \ub4e4\uc778 \uc74c\uc2dd\uc744 \uc900\ube44\ud588\uc5c8\uac70\ub4e0\uc694.\n\ubb3c\ub860 \uc815\ub9d0 \uc88b\uc558\uc8e0.", "start": 659.76, "duration": 3.274}, {"text": "\uc5ec\ub7ec \uac00\uc9c0 \ub2e4\uc591\ud55c \uc74c\uc2dd\uc744 \uc990\uacbc\uace0, \uc544\uc8fc \ub9db\uc788\uc5c8\uc5b4\uc694.\n\uadf8\ub7f0\ub370 \uc9c4\uc9dc\ub85c \uc0c8\ubcbd 2\uc2dc\uae4c\uc9c0 \uc124\uac70\uc9c0\ud574\uc57c \ud588\uc5b4\uc694.", "start": 663.059, "duration": 4.332}, {"text": "\uadf8\ub798\uc11c \uacb0\uad6d \"\ub2e4\uc2e0 \uc548 \ud574\" \uc774\ub807\uac8c \ub2e4\uc9d0\ud588\ub124\uc694.", "start": 667.416, "duration": 2.264}, {"text": "\uadf8\uac83\ub3c4 \uc0ac\uc2e4\uc774\uc5d0\uc694. \uc81c\uac00 \uce5c\uad6c\ub97c \ucd08\ub300\ud558\ub294 \uac83\uc5d0 \ub300\ud574\uc11c\n\ub9d0 \uc548 \ud558\uace0 \uc9c0\ub098\uac04 \ubd80\ubd84\uc774 \uc788\ub294\ub370, \uc9d1 \uc804\uccb4\ub97c \uccad\uc18c\ud558\uace0,", "start": 669.705, "duration": 9.943}, {"text": "\ub098\uc911\uc5d0 \uc124\uac70\uc9c0\ub3c4 \ub2e4 \ud558\uace0, \uc774\uac83\uc800\uac83 \ud574\uc57c \ud55c\ub2e4\ub294 \uc810\uc774\uc5c8\uc5b4\uc694.\n\ubc18\uba74\uc5d0 \uc678\uc2dd\ud560 \ub550 \uadf8\ub7f0 \uac74 \uc804\ud600 \uc0dd\uac01\ud560 \ud544\uc694\uac00 \uc5c6\uc8e0.", "start": 679.673, "duration": 8.577}, {"text": "\uadf8\ub7ec\ub2c8\uae4c\uc694. \uadf8\ub9ac\uace0 \ub2e4\ub978 \uc0ac\ub78c\uc774 \ub9cc\ub4e0 \uc74c\uc2dd\uc740\n\ub0b4\uac00 \ub9cc\ub4e0 \uac83\ubcf4\ub2e4 \ud6e8\uc52c \ub098\uc744 \ub54c\uac00 \ub9ce\uc544\uc694.", "start": 688.275, "duration": 8.211}, {"text": "\uc608\ub97c \ub4e4\uc5b4, \uc800\ub294 \ud654\ub355\uc774 \uc5c6\uac70\ub4e0\uc694.\n\uadf8\ub798\uc11c \uc774\ud0c8\ub9ac\uc544 \ud53c\uc790\ub294 \ub9cc\ub4e4 \uc218\uac00 \uc5c6\uc5b4\uc694.", "start": 696.511, "duration": 4.901}, {"text": "\uc74c, \ub9de\ub294 \ub9d0\uc774\ub124\uc694.", "start": 701.437, "duration": 1.048}, {"text": "\uadf8\ub7ec\ub2c8 \uac00\ub054\uc740 \uc678\uc2dd\ub3c4 \uac00\uce58\uac00 \uc788\uc8e0.", "start": 702.51, "duration": 1.65}, {"text": "\uadf8\ub7f0 \uac83 \uac19\uc544\uc694. \uc81c\uac00 \uae30\uc5b5\ud55c \uac8c \ub9de\ub2e4\uba74,\n\ud55c \ud559\uc0dd\uc774 \uc800\uc5d0\uac8c \uc774\ub7f0 \ub9d0\uc744 \ud55c \uc801\uc774 \uc788\ub294\ub370\uc694.", "start": 704.185, "duration": 6.038}, {"text": "\uc74c\uc2dd \uc790\uccb4\ub294 \uc804\ud600 \ub04c\ub9ac\uc9c0 \uc54a\ub294\ub370\uc694.\n\uc74c\uc2dd\uc774 \ub9db\uc788\ub294\uc9c0 \uc544\ub2cc\uc9c0\ub3c4 \uc2e0\uacbd \uc4f0\uc9c0 \uc54a\ub294\ub2e4\uace0 \ud558\ub354\ub77c\uace0\uc694.", "start": 710.248, "duration": 6.31}, {"text": "\uc800\ub3c4 \uc870\uae08\uc740 \uacf5\uac10\ud560 \uc218 \uc788\uc5c8\uc5b4\uc694.", "start": 716.583, "duration": 2.687}, {"text": "\uc800\ub3c4 \uc774\ud574\ud574\uc694. \uc5b4\ub5a4 \uc0ac\ub78c\ub4e4\uc5d0\uac90 \uadf8\ub0e5 \uc2e4\uc6a9\uc801\uc778 \uac70\uc8e0.\n\uc0dd\uc874\uc744 \uc704\ud55c \uc218\ub2e8\uc77c \ubfd0\uc778 \uac70\uc608\uc694.", "start": 719.295, "duration": 5.88}, {"text": "\ub9de\uc544\uc694. \uc800\ub3c4 \uac00\ub054 \uadf8\ub7f0 \ub290\ub08c\uc774 \ub4e4 \ub54c\uac00 \uc788\uc5b4\uc694.\n\uc544\ub9c8 \uadf8\ub798\uc11c\uc778 \uac83 \uac19\uc740\ub370\uc694.", "start": 725.2, "duration": 5.93}, {"text": "\"\uaf2d \uc678\uc2dd\ud558\ub7ec \uac00\uc57c\uaca0\ub2e4\" \ub77c\ub4e0\uac00 \"\uc774 \uc74c\uc2dd\uc744 \ub108\ubb34 \uba39\uace0 \n\uc2f6\uc73c\ub2c8 \ub098\uac00\uc11c \uba39\uc5b4\uc57c\uaca0\uc5b4\"\ub77c\ub294 \uc0dd\uac01\uc774 \ub4e4\uc9c0\ub294 \uc54a\ub354\ub77c\uace0\uc694.", "start": 731.155, "duration": 9.908}, {"text": "\uadf8\ub7f0 \ub290\ub08c\uc740 \uc798 \ubc1b\uc9c0 \uc54a\uc544\uc694.", "start": 741.088, "duration": 1.315}, {"text": "\uc81c \uc5b8\ub2c8\ub3c4 \ud56d\uc0c1 \ubaa8\ub4e0 \uc74c\uc2dd\uc774\n\uc815\uc2e0\uc801\uc778 \uacbd\ud5d8\uc77c \ud544\uc694\ub294 \uc5c6\ub2e4\uace0 \ub9d0\ud574\uc694.", "start": 742.428, "duration": 4.384}, {"text": "\uac00\ub054\uc740 \ub531 \ub9de\ub294 \uc74c\uc2dd\uc774 \uc544\ub2c8\uac70\ub098, \ub9db\uc788\uc9c0 \uc54a\uac70\ub098,\n\uc5b4\uc81c \ub0a8\uae34 \uc74c\uc2dd\uc774\ub354\ub77c\ub3c4 \uadf8\ub0e5 \uba39\uc5b4\uc57c \ud560 \ub54c\ub3c4 \uc788\ub294 \uac70\uc8e0.", "start": 746.837, "duration": 5.78}, {"text": "\uadf8\ub798\ub3c4 \ub0a8\uc740 \uc74c\uc2dd\uc5d0 \ub300\ud55c \uc88b\uc740 \ud301\uc744 \ub4e4\uc740 \uc801\uc774 \uc788\ub294\ub370\uc694.\n\ub0a8\uc740 \uc74c\uc2dd\uc774 \ud56d\uc0c1 \ubb38\uc81c\uc796\uc544\uc694?", "start": 752.642, "duration": 5.114}, {"text": "\uadf8\uac78 \uba39\ub294 \uac8c \ud569\ub9ac\uc801\uc774\ub77c\ub294 \uac74 \uc54c\uace0 \uc788\uc5b4\uc694.\n\uc804 \uc74c\uc2dd\uc744 \ub0ad\ube44\ud558\ub294 \uc77c\uc774 \uc5c6\uac70\ub4e0\uc694.", "start": 757.781, "duration": 5.085}, {"text": "\uc81c\uac00 \ub4e4\uc740 \uc88b\uc740 \ud301\uc774 \ubb50\uc600\ub0d0\uba74, \uadf8\uac78 \ub610 \ub2e4\ub978 \uba54\ub274\ub85c\n\ubcc0\uc2e0\uc2dc\ucf1c \ubcf4\ub77c\ub294 \uac70\uc600\uc5b4\uc694. \uc0c8\ub85c\uc6b4 \uc74c\uc2dd\uc73c\ub85c\uc694.", "start": 762.891, "duration": 6.829}, {"text": "\ub9de\uc544\uc694!", "start": 769.745, "duration": 0.96}, {"text": "\uadf8\ub7fc \uc0c8\ub85c\uc6b4 \uc74c\uc2dd\uc744 \uba39\ub294 \ub290\ub08c\uc774 \ub098\ub2c8\uae4c\uc694.\n\uadf8\ub7f0\ub370 \uc870\uc2ec\ud574\uc57c \ud560 \uc810\uc774 \uc788\ub294\ub370\uc694.", "start": 770.705, "duration": 3.953}, {"text": "\uc7ac\ub8cc\ub97c \ucd94\uac00\ud574\uc11c \ub9cc\ub4e4\ub2e4 \ubcf4\uba74 \uadf8 \uc74c\uc2dd\uc744 \ub2e4\n\ubabb \uba39\uac8c \ub418\uace0, \uadf8\ub7fc \ub610 \ub0a8\ub294 \uc74c\uc2dd\uc774 \uc0dd\uae30\uac70\ub4e0\uc694.", "start": 774.683, "duration": 4.766}, {"text": "\uacb0\uad6d \uc601\uc6d0\ud55c \ub0a8\uc740 \uc74c\uc2dd\uc758 \uad74\ub808\uc5d0 \ube60\uc9c0\uac8c \ub420 \uc218 \uc788\uc5b4\uc694.\n\uc81c\uac00 \uacaa\uc740 \uc77c\uc774\ub78d\ub2c8\ub2e4.", "start": 779.474, "duration": 5.051}, {"text": "\uadf8\uac74 \uc800\ub3c4 \uc5b4\ub5bb\uac8c \ud574\uc57c \ud560\uc9c0 \ubaa8\ub974\uaca0\ub124\uc694. \uc800\ub294 \uadf8\ub0e5\n\ub0a8\uc740 \uc74c\uc2dd \uadf8\ub300\ub85c \uba39\uc5b4\uc694. \ub370\uc6cc\uc11c \uba39\uc5b4\ubc84\ub9ac\ub294 \uac70\uc8e0.", "start": 784.55, "duration": 5.19}, {"text": "\uc800\ub3c4 \uac00\ub054\uc740 \uadf8\ub807\uac8c \ud574\uc694.", "start": 789.765, "duration": 1.295}, {"text": "\ub124.", "start": 791.06, "duration": 0.6}, {"text": "\uadf8\ub798\uc57c \ud560 \ub54c\uac00 \uc788\uc73c\ub2c8\uae4c\uc694.", "start": 791.66, "duration": 0.87}, {"text": "\uadf8\ub7ec\uac8c\uc694. \ucc38\uace0\ub85c \uc598\uae30\ud558\uba74 \uc88b\uc744 \uac83 \uac19\uc544\uc11c \ub9d0\uc500\ub4dc\ub9ac\ub294\ub370\uc694.\n\ud55c\uad6d\ub3c4 \ube44\uc2b7\ud55c\uc9c0\ub294 \ubaa8\ub974\uaca0\ub294\ub370,", "start": 792.54, "duration": 7.544}, {"text": "\uc81c\uac00 \uc911\uad6d\uc5d0 \uc0b4 \ub54c \uc601\uad6d\uc5d0\uc11c \uc678\uc2dd\ud558\ub294 \ube44\uc6a9\uc774\n\uc911\uad6d\ubcf4\ub2e4 10\ubc30 \uc815\ub3c4 \ub354 \ube44\uc2f8\ub2e4\ub294 \uac78 \ub290\uaf08\uac70\ub4e0\uc694.", "start": 800.109, "duration": 9.686}, {"text": "\uc815\ub9d0 \uc2ec\ud558\ub124\uc694.", "start": 809.82, "duration": 0.5}, {"text": "\ub124. \uadf8\ub798\uc11c \n\"\uc601\uad6d\uc5d0\uc11c \uc678\uc2dd\ud558\ub294 \uac74 \uc815\ub9d0 \ube44\uc2f8\ub2e4\"\ub77c\uace0 \ud588\uc744 \ub54c,", "start": 810.343, "duration": 6.028}, {"text": "\uadf8\uac8c \uc5b4\ub290 \uc815\ub3c4\ub85c \ube44\uc2fc \uac74\uc9c0\n\ub300\ub7b5 \uc9d0\uc791\ud558\uc2e4 \uc218 \uc788\uc744 \uac83 \uac19\uc544\uc694.", "start": 816.396, "duration": 4.619}, {"text": "\ub124. \uc194\uc9c1\ud788 \uadf8\uac8c \uc800\ud55c\ud150 \uac00\ub054 \uc815\ub9d0 \ud070 \uc601\ud5a5\uc744 \ubbf8\uccd0\uc694.\n\uc81c\uac00 \ubc16\uc5d0 \uc678\ucd9c\ud560 \ub550 \uaf64 \uacc4\ud68d\uc801\uc73c\ub85c \uc6c0\uc9c1\uc774\ub824\uace0 \ud558\uac70\ub4e0\uc694.", "start": 821.04, "duration": 8.084}, {"text": "\uc608\ub97c \ub4e4\uc5b4, \uc81c\uac00 \ubc84\uc2a4\ub97c \ud0c8 \uc77c\uc774 \uc788\uac70\ub098 \uadf8\ub7f4 \ub550\n\uc0cc\ub4dc\uc704\uce58\ub97c \ucc59\uae30\ub824\uace0 \ud558\ub294 \ud3b8\uc774\uc8e0.", "start": 829.149, "duration": 3.656}, {"text": "\uadf8\ub7f0\ub370 \ud55c \ubc88\uc740 \uc7a5\uac70\ub9ac \uc5ec\ud589\uc744 \ub5a0\ub0ac\ub294\ub370\n\ud3c9\uc18c\ucc98\ub7fc \ubb54\uac00\ub97c \ucc59\uae38 \uc2dc\uac04\uc774 \uc5c6\uc5c8\ub358 \uac70\uc608\uc694.", "start": 832.83, "duration": 3.743}, {"text": "\uc6cc\ub099 \uc774\ub3d9\uc774 \ub9ce\uc558\uac70\ub4e0\uc694. \uadf8\ub798\uc11c \uba39\uc744 \uac8c \uc804\ud600 \uc5c6\uc5c8\uc5b4\uc694.", "start": 836.598, "duration": 4.525}, {"text": "\uacb0\uad6d \uadf8\ub809\uc2a4(Greggs) \uac19\uc740\n\uac04\ub2e8\ud55c \ud14c\uc774\ud06c\uc544\uc6c3 \uc804\ubb38\uc810\uc5d0 \uac08 \uc218\ubc16\uc5d0 \uc5c6\uc5c8\uc8e0.", "start": 841.148, "duration": 3.755}, {"text": "\uac70\uae30 \uc74c\uc2dd\ub3c4 \uaf64 \ube44\uc2f8\uac70\ub4e0\uc694. \uc0cc\ub4dc\uc704\uce58 \ud558\ub098\ub3c4\n4\ud30c\uc6b4\ub4dc \uc815\ub3c4 \ud558\uace0, \uac74\uac15\ud55c \uc74c\uc2dd\ub3c4 \uc544\ub2c8\uc796\uc544\uc694.", "start": 844.928, "duration": 5.061}, {"text": "\uc18c\uc2dc\uc9c0 \ub864\uc774\ub098 \ud53c\uc790 \uac19\uc740 \uac8c \ub300\ubd80\ubd84\uc774\uc5d0\uc694.\n\uadf8\ub7f0\ub370 \uc0cc\ub4dc\uc704\uce58\ub97c \ube7c\uba74 \ub531\ud788 \uba39\uc744 \ub9cc\ud55c \uac83\ub3c4 \uc5c6\uc5b4\uc694.", "start": 850.014, "duration": 5.462}, {"text": "\uadf8\ub798\uc11c \uac00\ub054\uc740 \uc815\ub9d0 \ubd88\ud3b8\ud55c \uac83 \uac19\uc544\uc694. 35\ud30c\uc6b4\ub4dc\uc9dc\ub9ac \uc2dd\uc0ac\ub97c\n\ud558\uac70\ub098 \uc18c\uc2dc\uc9c0 \ub864\uc744 \uba39\uac70\ub098 \ub458 \uc911\uc5d0 \ud558\ub098\ubfd0\uc778 \ub290\ub08c\uc774\uc5d0\uc694.", "start": 855.501, "duration": 6.469}, {"text": "\uc815\ub9d0 \uadf8\ub798\uc694. \uc911\uac04\uc774 \uc815\ub9d0 \uc5c6\uc5b4\uc694.", "start": 861.995, "duration": 3.97}, {"text": "\ub124.", "start": 865.989, "duration": 0.5}, {"text": "\uc678\uc2dd\uc5d0 \ub300\ud574 \uc0c1\ub2f9\ud55c \ubd88\ud3b8\uc744 \ub298\uc5b4 \ub193\uc558\ub124\uc694.\n\uadf8\uac83\ub3c4 \uc88b\uc544\uc694.", "start": 866.511, "duration": 4.781}, {"text": "\uc624\ub298\uc740 \uc6b0\ub9ac \ub458 \ub2e4 '\uc9d1\uc5d0\uc11c \uc694\ub9ac\ud558\uae30'\ub77c\ub294\n\uac19\uc740 \uac78 \uace8\ub790\uc5b4\uc694.", "start": 871.317, "duration": 6.22}, {"text": "\ud559\uc0dd\ubd84\ub4e4\ub3c4 \uac19\uc740 \uac78 \uace8\ub790\ub294\uc9c0 \ubcf4\uba74 \uc7ac\ubc0c\uc744 \uac83 \uac19\ub124\uc694.\n\uadf8\ub7f4 \uac83 \uac19\uc9c4 \uc54a\uc9c0\ub9cc\uc694.", "start": 877.562, "duration": 4.103}, {"text": "\uc544\ub9c8 \uc544\ub2d0 \uac70\uc608\uc694.", "start": 881.69, "duration": 0.725}, {"text": "\ub124. \uc544\ub9c8 \uc544\ub2d0 \uac78\uc694.\n\uc5ec\ub7ec\ubd84\uc758 \uc120\ud0dd\uc744 \ub313\uae00\ub85c \ub0a8\uaca8\uc8fc\uc2dc\uba74 \uc88b\uaca0\uc5b4\uc694.", "start": 882.44, "duration": 3.576}, {"text": "\uc65c \uc9d1\uc5d0\uc11c \uc694\ub9ac\ud558\ub294 \uac83\ubcf4\ub2e4 \ub098\uac00\uc11c \uba39\ub294 \uac8c\n\ud6e8\uc52c \ub354 \uc88b\uc740\uc9c0\ub3c4 \uc54c\ub824\uc8fc\uc138\uc694.", "start": 886.041, "duration": 5.509}, {"text": "\uadf8\ub7fc\uc694.", "start": 891.575, "duration": 1.175}, {"text": "\ub298 \uadf8\ub807\ub4ef\uc774 \uc624\ub298\ub3c4 \ub9cc\ub098\uc11c \ubc18\uac00\uc6e0\uc5b4\uc694, \uc120\uc0dd\ub2d8.\n\uccad\ucde8\uc790\ubd84\ub4e4\ub3c4 \uc88b\uc740 \ud558\ub8e8 \ubcf4\ub0b4\uc2dc\uae38 \ubc14\ub784\uac8c\uc694.", "start": 892.775, "duration": 6.964}, {"text": "\ub2e4\uc74c \uc5d0\ud53c\uc18c\ub4dc\uc5d0\uc11c \ub2e4\uc2dc \ub9cc\ub098\uc694.", "start": 899.764, "duration": 2.016}, {"text": "\ubab8 \uc798 \ucc59\uae30\uc2dc\uace0\uc694. \uc548\ub155\ud788 \uacc4\uc138\uc694.", "start": 901.805, "duration": 1.415}, {"text": "\uc548\ub155\ud788 \uacc4\uc138\uc694.", "start": 903.245, "duration": 2.76}]]
